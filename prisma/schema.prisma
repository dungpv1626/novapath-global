generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  category    String
  author      String
  authorRole  String
  coverImage  String
  readTime    String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model University {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameEn      String
  city        String
  rank        Int
  established Int
  students    String
  programs    String
  tuition     String
  highlights  String
  img         String
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Scholarship {
  id         String   @id @default(cuid())
  name       String
  amount     String
  conditions String
  popular    Boolean  @default(false)
  gradient   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Course {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  level     String
  duration  String
  price     String
  schedule  String
  image     String
  tag       String
  rating    Float    @default(5.0)
  students  String
  tab       String   @default("co-ban")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  school    String
  content   String
  avatar    String
  rating    Int      @default(5)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id        String   @id @default(cuid())
  name      String
  meta      String
  image     String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Program {
  id        String   @id @default(cuid())
  title     String
  tag       String
  tab       String
  rating    Float    @default(4.9)
  reviews   String   @default("0")
  duration  String
  note      String
  price     String
  priceUnit String   @default("năm")
  image     String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id           String   @id @default("main")
  heroTitle    String   @default("Chinh phục giấc mơ du học Trung Quốc")
  heroSubtitle String   @default("NOVAPATH GLOBAL chuyên tư vấn du học Trung Quốc: chọn trường, làm hồ sơ, săn học bổng và đào tạo tiếng Trung — minh bạch, tận tâm, đúng lộ trình.")
  statVisa     Int      @default(98)
  statSchools  Int      @default(500)
  statYears    Int      @default(12)
  phone        String   @default("1900 6868")
  email        String   @default("tuvan@novapath.vn")
  facebook     String   @default("#")
  instagram    String   @default("#")
  youtube      String   @default("#")
  updatedAt    DateTime @updatedAt
}
